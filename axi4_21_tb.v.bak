`timescale 1ns / 1ps

module axi4_21_tb();

    // =========================================================================
    // 1. KHAI BÁO CÁC TÍN HIỆU (SIGNALS DECLARATION)
    // =========================================================================
    
    // System Signals
    logic        ACLK_i;
    logic        ARESETn_i; // Active LOW reset

    // --------------------------------------------------------
    // Tín hiệu Input (Đi vào DUT) - Gán giá trị từ Testbench
    // --------------------------------------------------------
    // Master Interface Inputs
    logic  [0:0] m_ARVALID_i;
    logic  [0:0] m_AWVALID_i;
    logic  [0:0] m_BREADY_i;
    logic  [0:0] m_RREADY_i;
    logic  [0:0] m_WLAST_i;
    logic  [0:0] m_WVALID_i;
    
    logic  [4:0] m_AWID_i;
    logic [31:0] m_AWADDR_i;
    logic  [1:0] m_AWBURST_i;
    logic  [2:0] m_AWLEN_i;
    logic  [2:0] m_AWSIZE_i;
    logic [31:0] m_WDATA_i;
    
    logic  [4:0] m_ARID_i;
    logic [31:0] m_ARADDR_i;
    logic  [1:0] m_ARBURST_i;
    logic  [2:0] m_ARLEN_i;
    logic  [2:0] m_ARSIZE_i;

    // Slave Interface Inputs
    logic  [1:0] s_AWREADY_i;
    logic  [1:0] s_WREADY_i;
    logic  [9:0] s_BID_i;
    logic  [3:0] s_BRESP_i;
    logic  [1:0] s_BVALID_i;
    
    logic  [1:0] s_ARREADY_i;
    logic  [9:0] s_RID_i;
    logic [63:0] s_RDATA_i;
    logic  [3:0] s_RRESP_i;
    logic  [1:0] s_RLAST_i;
    logic  [1:0] s_RVALID_i;

    // --------------------------------------------------------
    // Tín hiệu Output (Đi ra từ DUT) - Dùng để quan sát (Monitor)
    // --------------------------------------------------------
    // Master Interface Outputs
    logic  [0:0] m_ARREADY_o;
    logic  [0:0] m_AWREADY_o;
    logic  [0:0] m_BVALID_o;
    logic  [0:0] m_RLAST_o;
    logic  [0:0] m_RVALID_o;
    logic  [0:0] m_WREADY_o;
    
    logic  [4:0] m_BID_o;
    logic  [1:0] m_BRESP_o;
    logic  [4:0] m_RID_o;
    logic [31:0] m_RDATA_o;
    logic  [1:0] m_RRESP_o;

    // Slave Interface Outputs
    logic  [9:0] s_AWID_o;
    logic [63:0] s_AWADDR_o;
    logic  [3:0] s_AWBURST_o;
    logic  [5:0] s_AWLEN_o;
    logic  [5:0] s_AWSIZE_o;
    logic  [1:0] s_AWVALID_o;
    
    logic [63:0] s_WDATA_o;
    logic  [1:0] s_WLAST_o;
    logic  [1:0] s_WVALID_o;
    logic  [1:0] s_BREADY_o;
    
    logic  [9:0] s_ARID_o;
    logic [63:0] s_ARADDR_o;
    logic  [3:0] s_ARBURST_o;
    logic  [5:0] s_ARLEN_o;
    logic  [5:0] s_ARSIZE_o;
    logic  [1:0] s_ARVALID_o;
    logic  [1:0] s_RREADY_o;

    // =========================================================================
    // 2. KHỞI TẠO KHỐI DUT (DEVICE UNDER TEST)
    // =========================================================================
    // Giả sử tên module của bạn là ai_dispatcher
    ai_dispatcher dut (
        // System
        .ACLK_i          (ACLK_i),
        .ARESETn_i       (ARESETn_i),
        
        // Master inputs
        .m_ARVALID_i     (m_ARVALID_i),
        .m_AWVALID_i     (m_AWVALID_i),
        .m_BREADY_i      (m_BREADY_i),
        .m_RREADY_i      (m_RREADY_i),
        .m_WLAST_i       (m_WLAST_i),
        .m_WVALID_i      (m_WVALID_i),
        .m_AWID_i        (m_AWID_i),
        .m_AWADDR_i      (m_AWADDR_i),
        .m_AWBURST_i     (m_AWBURST_i),
        .m_AWLEN_i       (m_AWLEN_i),
        .m_AWSIZE_i      (m_AWSIZE_i),
        .m_WDATA_i       (m_WDATA_i),
        .m_ARID_i        (m_ARID_i),
        .m_ARADDR_i      (m_ARADDR_i),
        .m_ARBURST_i     (m_ARBURST_i),
        .m_ARLEN_i       (m_ARLEN_i),
        .m_ARSIZE_i      (m_ARSIZE_i),
        
        // Slave inputs
        .s_AWREADY_i     (s_AWREADY_i),
        .s_WREADY_i      (s_WREADY_i),
        .s_BID_i         (s_BID_i),
        .s_BRESP_i       (s_BRESP_i),
        .s_BVALID_i      (s_BVALID_i),
        .s_ARREADY_i     (s_ARREADY_i),
        .s_RID_i         (s_RID_i),
        .s_RDATA_i       (s_RDATA_i),
        .s_RRESP_i       (s_RRESP_i),
        .s_RLAST_i       (s_RLAST_i),
        .s_RVALID_i      (s_RVALID_i),

        // Master outputs
        .m_ARREADY_o     (m_ARREADY_o),
        .m_AWREADY_o     (m_AWREADY_o),
        .m_BVALID_o      (m_BVALID_o),
        .m_RLAST_o       (m_RLAST_o),
        .m_RVALID_o      (m_RVALID_o),
        .m_WREADY_o      (m_WREADY_o),
        .m_BID_o         (m_BID_o),
        .m_BRESP_o       (m_BRESP_o),
        .m_RID_o         (m_RID_o),
        .m_RDATA_o       (m_RDATA_o),
        .m_RRESP_o       (m_RRESP_o),

        // Slave outputs
        .s_AWID_o        (s_AWID_o),
        .s_AWADDR_o      (s_AWADDR_o),
        .s_AWBURST_o     (s_AWBURST_o),
        .s_AWLEN_o       (s_AWLEN_o),
        .s_AWSIZE_o      (s_AWSIZE_o),
        .s_AWVALID_o     (s_AWVALID_o),
        .s_WDATA_o       (s_WDATA_o),
        .s_WLAST_o       (s_WLAST_o),
        .s_WVALID_o      (s_WVALID_o),
        .s_BREADY_o      (s_BREADY_o),
        .s_ARID_o        (s_ARID_o),
        .s_ARADDR_o      (s_ARADDR_o),
        .s_ARBURST_o     (s_ARBURST_o),
        .s_ARLEN_o       (s_ARLEN_o),
        .s_ARSIZE_o      (s_ARSIZE_o),
        .s_ARVALID_o     (s_ARVALID_o),
        .s_RREADY_o      (s_RREADY_o)
    );

    // =========================================================================
    // 3. TẠO XUNG CLOCK (CLOCK GENERATION)
    // =========================================================================
    // Tạo xung clock chu kỳ 10ns (100MHz)
    initial begin
        ACLK_i = 0;
        forever #5 ACLK_i = ~ACLK_i; 
    end

    // =========================================================================
    // 4. KỊCH BẢN MÔ PHỎNG (MAIN TEST STIMULUS)
    // =========================================================================
    initial begin
        // 4.1 Khởi tạo toàn bộ tín hiệu đầu vào bằng 0 để tránh state 'X' (Unknown)
        ARESETn_i   = 0; // Kích hoạt Reset (Active Low)
        m_ARVALID_i = 0; m_AWVALID_i = 0; m_BREADY_i  = 0; m_RREADY_i  = 0;
        m_WLAST_i   = 0; m_WVALID_i  = 0;
        m_AWID_i    = 0; m_AWADDR_i  = 0; m_AWBURST_i = 0; m_AWLEN_i   = 0; m_AWSIZE_i = 0;
        m_WDATA_i   = 0;
        m_ARID_i    = 0; m_ARADDR_i  = 0; m_ARBURST_i = 0; m_ARLEN_i   = 0; m_ARSIZE_i = 0;

        s_AWREADY_i = 0; s_WREADY_i  = 0; s_BID_i     = 0; s_BRESP_i   = 0; s_BVALID_i = 0;
        s_ARREADY_i = 0; s_RID_i     = 0; s_RDATA_i   = 0; s_RRESP_i   = 0; s_RLAST_i  = 0; s_RVALID_i = 0;

        // 4.2 Giữ Reset trong vài chu kỳ clock
        repeat(5) @(posedge ACLK_i);
        ARESETn_i = 1; // Nhả Reset
        $display("System Reset De-asserted. Starting test...");

        // 4.3 Template viết giao dịch AXI (Ví dụ: Master Write Request)
        @(posedge ACLK_i);
        // ... Viết kịch bản test của bạn tại đây ...
        // Ví dụ: Set địa chỉ ghi
        // m_AWADDR_i  = 32'h1000_0000;
        // m_AWVALID_i = 1'b1;
        
        // Đợi phản hồi AWREADY từ Slave/Dispatcher
        // wait(m_AWREADY_o == 1'b1);
        // @(posedge ACLK_i);
        // m_AWVALID_i = 1'b0;

        
        // 4.4 Kết thúc mô phỏng
        #1000;
        $display("Simulation Finished!");
        $finish;
    end

endmodule